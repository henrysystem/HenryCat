# ====================================
# HenryCat Configuration
# ====================================

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# ====================================
# Path Configuration (IMPORTANT!)
# ====================================

# Root path to scan for files
# Examples:
#   Windows: E:/ or C:/Users/YourName/Documents
#   Linux/Mac: /home/username/media or /Users/username/Documents
# Leave empty to scan parent directory of HenryCat installation
SCAN_ROOT_PATH=

# Directories to scan (comma-separated, relative to SCAN_ROOT_PATH)
# Examples:
#   CURSOS,Libros,INSTALADORES (default)
#   Courses,Books,Software
#   Videos,PDFs,Downloads
SCAN_DIRECTORIES=CURSOS,Libros,INSTALADORES

# Database path (relative to project or absolute)
DATABASE_PATH=./data/catalog.db

# Assets path for generated posters (relative to project or absolute)
ASSETS_PATH=./assets

# Vector Store Configuration
FAISS_INDEX_PATH=./data/vectors.faiss

# ====================================
# Server Configuration
# ====================================
HOST=0.0.0.0
PORT=8000
DEBUG=False

# ====================================
# GitHub Configuration (for developers)
# ====================================
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_USERNAME=your_github_username
GITHUB_REPO=HenryCat

# ====================================
# Optional: Logging
# ====================================
LOG_LEVEL=INFO
LOG_FILE=./logs/henrycat.log
